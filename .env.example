# Kalshi API Credentials
# Get your API key from https://kalshi.com/settings/api
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Environment (production or demo)
# Demo API for testing (no real money):
# KALSHI_API_URL=https://demo-api.kalshi.co/trade-api/v2
# Production API:
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2

# Trading Parameters
MAX_POSITION_SIZE=50
MAX_DAILY_LOSS=100
KELLY_FRACTION=0.5

# DeepStack Integration (optional)
DEEPSTACK_PATH=/path/to/deepstack
DEEPSTACK_API_URL=http://localhost:8000

# Journal Database Path (optional)
KALSHI_JOURNAL_DB=./trade_journal.db

# Telegram notifications (optional)
DAE_TELEGRAM_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Claude Code CLI for self-repair (optional, auto-detected if on PATH)
# CLAUDE_CLI_PATH=/path/to/claude

# Anthropic API for AI heartbeat (optional)
ANTHROPIC_API_KEY=your-anthropic-key

# Supabase for dashboard sync (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# launchd service name for self-restart (optional, default: com.id8labs.deepstack-bot)
# LAUNCHD_SERVICE=com.yourorg.deepstack-bot
