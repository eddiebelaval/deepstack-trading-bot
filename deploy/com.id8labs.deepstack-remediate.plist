<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Tier 2 watchdog + remediation. This is the ONLY monitoring layer that
  lives outside the bot process — it carries the dead-man switch that
  alerts when Dae's health row goes stale (i.e. the process is down).

  Install: update BOTH absolute paths below to your checkout, then:
    cp deploy/com.id8labs.deepstack-remediate.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$UID ~/Library/LaunchAgents/com.id8labs.deepstack-remediate.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.id8labs.deepstack-remediate</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/eddiebelaval/clawd/projects/kalshi-trading/scripts/remediate-launcher.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/eddiebelaval/clawd/projects/kalshi-trading</string>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/tmp/deepstack-remediate.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/deepstack-remediate.err</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
