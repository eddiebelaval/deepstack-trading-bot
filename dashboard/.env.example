# PostgreSQL Database Configuration
# Copy this to .env.local and update values

# Option 1: Connection string (preferred)
DATABASE_URL=postgresql://localhost:5432/kalshi_trading

# Option 2: Individual params
PGHOST=localhost
PGPORT=5432
PGDATABASE=kalshi_trading
PGUSER=your_username
PGPASSWORD=your_password

# For Supabase (if using cloud):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
