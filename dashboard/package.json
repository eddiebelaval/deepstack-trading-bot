{
  "name": "dashboard",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "dev:clean": "rm -rf .next && next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/migrate.ts",
    "db:setup": "createdb kalshi_trading 2>/dev/null || true && npm run db:migrate",
    "db:reset": "dropdb kalshi_trading --if-exists && createdb kalshi_trading && npm run db:migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:db:setup": "createdb kalshi_trading_test 2>/dev/null || true && PGDATABASE=kalshi_trading_test npm run db:migrate",
    "test:db:reset": "dropdb kalshi_trading_test --if-exists && createdb kalshi_trading_test && PGDATABASE=kalshi_trading_test npm run db:migrate",
    "test:all": "npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.16.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "next": "14.2.35",
    "pg": "^8.17.2",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "playwright": "^1.58.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
